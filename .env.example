# === FastAPI Server ===
APP_ENV=development                     # development | staging | production
APP_PORT=8000
APP_HOST=0.0.0.0
SECRET_KEY=your-secret-key-here        # For JWT signing
LOG_LEVEL=INFO

# === Dify Configuration ===
DIFY_BASE_URL=http://localhost:80/v1   # Dify API URL (internal)
DIFY_CONSOLE_URL=http://localhost:80   # Dify Console UI
DIFY_API_KEY_SALES=app-xxxxx           # Dify App API key cho Sales
DIFY_API_KEY_HR=app-xxxxx              # Dify App API key cho HR
DIFY_API_KEY_ACCOUNTING=app-xxxxx      # Dify App API key cho Accounting
DIFY_API_KEY_GENERAL=app-xxxxx         # Dify App API key cho General
DIFY_API_KEY_MANAGEMENT=app-xxxxx      # Dify App API key cho Management
DIFY_DATASET_API_KEY=dataset-xxxxx     # Dify Dataset API key (for upload)

# Dify Dataset IDs (get from Dify Console after creating KBs)
DIFY_DATASET_ID_SALES=                 # KB Sales dataset ID
DIFY_DATASET_ID_HR=                    # KB HR dataset ID
DIFY_DATASET_ID_ACCOUNTING=            # KB Accounting dataset ID
DIFY_DATASET_ID_GENERAL=               # KB General dataset ID
DIFY_DATASET_ID_MANAGEMENT=            # KB Management dataset ID

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Used by Dify as LLM provider

# === OpenAI API (Phase 1 Embedding) ===
OPENAI_API_KEY=sk-xxxxx               # Used by Dify for embedding

# === Database ===
DATABASE_URL=postgresql+asyncpg://vihat:password@localhost:5432/vihat_knowledge
DB_PASSWORD=your-db-password

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === OmiFlow Webhook ===
OMIFLOW_WEBHOOK_SECRET=your-webhook-secret
OMIFLOW_API_URL=https://api.omiflow.vn
OMIFLOW_API_KEY=your-omiflow-api-key

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/webhook/telegram

# === File Upload ===
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=50

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500
